      "meaning": "to do (conditional - present)",
      "tense": "conditional",
      "aspect": "imperfective",
      "conjugation": {
        "já (m)": "dělal bych",
        "já (f)": "dělala bych",
        "ty (m)": "dělal bys",
        "ty (f)": "dělala bys",
        "on": "dělal by",
        "ona": "dělala by",
        "ono": "dělalo by",
        "my (m)": "dělali bychom",
        "my (f)": "dělaly bychom",
        "vy (m)": "dělali byste",
        "vy (f)": "dělaly byste",
        "oni (m animate)": "dělali by",
        "ony (f/inanimate)": "dělaly by"
      },
      "notes": "Conditional = L-participle + bych/bys/by/bychom/byste/by. Enclitic word order applies: 'dělal bych to' (I would do it).",
      "example": {"cz": "Dělal bych to, kdybych měl čas.", "en": "I would do it if I had time."}

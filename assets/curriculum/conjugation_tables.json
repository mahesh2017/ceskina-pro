    {
      "id": "conj_fut_imperfective",
      "verb": "dělat (imperfective future)",
      "meaning": "to do (future - imperfective)",
      "tense": "future",
      "aspect": "imperfective",
      "conjugation": {
        "já": "budu dělat",
        "ty": "budeš dělat",
        "on/ona/ono": "bude dělat",
        "my": "budeme dělat",
        "vy": "budete dělat",
        "oni/ony": "budou dělat"
      },
      "notes": "Imperfective future = budu/budeš/bude/budeme/budete/budou + infinitive. Used for ongoing or habitual future actions.",
      "example": {"cz": "Budu dělat úkol zítra.", "en": "I will be doing my homework tomorrow."}
    },
    {
      "id": "conj_fut_perfective",
      "verb": "perfective verbs (future)",
      "meaning": "to do (future - perfective, completed actions)",
      "tense": "future",
      "aspect": "perfective",
      "conjugation": {
        "napíšu (psát)": "já napíšu, ty napíšeš, on napíše, my napíšeme, vy napíšete, oni napíšou",
        "řeknu (říct)": "já řeknu, ty řekneš, on řekne, my řekneme, vy řeknete, oni řeknou",
        "udělám (udělat)": "já udělám, ty uděláš, on udělá, my uděláme, vy uděláte, oni udělají",
        "koupím (koupit)": "já koupím, ty koupíš, on koupí, my koupíme, vy koupíte, oni koupí",
        "uvidím (vidět)": "já uvidím, ty uvidíš, on uvidí, my uvidíme, vy uvidíte, oni uvidí"
      },
      "notes": "Perfective verbs have present-tense forms that MEAN future. No 'budu' needed. Used for completed, one-time future actions.",
      "example": {"cz": "Napíšu ti zprávu.", "en": "I will write you a message."}
    },
    {
      "id": "conj_byt_future",
      "verb": "být (future)",
      "meaning": "to be (future)",
      "tense": "future",
      "aspect": "imperfective",
      "conjugation": {
        "já": "budu",
        "ty": "budeš",
        "on/ona/ono": "bude",
        "my": "budeme",
        "vy": "budete",
        "oni/ony": "budou"
      },
      "notes": "Future of být = budu/budeš/bude/budeme/budete/budou. Same auxiliary used for imperfective future of other verbs.",
      "example": {"cz": "Budu doma.", "en": "I will be at home."}
    },
    {

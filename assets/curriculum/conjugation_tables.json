{
  "title": "Czech Verb Conjugation Reference Tables",
  "description": "Complete conjugation paradigms for all verb types and tenses",
  "tables": [
    {
      "id": "conj_byt_present",
      "verb": "být",
      "meaning": "to be",
      "tense": "present",
      "aspect": "imperfective",
      "conjugation": {
        "já": "jsem",
        "ty": "jsi",
        "on/ona/ono": "je",
        "my": "jsme",
        "vy": "jste",
        "oni/ony": "jsou"
      },
      "notes": "Irregular. Subject pronoun usually omitted. Colloquially 'jsi' is often shortened to 'se' (ty se šikovný).",
      "example": {"cz": "Jsem student.", "en": "I am a student."}
    },
    {
      "id": "conj_mit_present",
      "verb": "mít",
      "meaning": "to have",
      "tense": "present",
      "aspect": "imperfective",
      "conjugation": {
        "já": "mám",
        "ty": "máš",
        "on/ona/ono": "má",
        "my": "máme",
        "vy": "máte",
        "oni/ony": "mají"
      },
      "notes": "Irregular. The 3rd person plural 'mají' is irregular (not 'májí').",
      "example": {"cz": "Mám nové auto.", "en": "I have a new car."}
    },
    {
